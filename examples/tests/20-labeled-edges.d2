# Test 20: Labeled edges
classes: {
  row-1-col-1: {style.opacity: 1}
  row-1-col-3: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
}

browser: Browser {class: row-1-col-1}
cdn: CDN {class: row-1-col-3}
api: API {class: row-2-col-2}
db: Database {
  shape: cylinder
  class: row-3-col-1
}
cache: Redis {
  shape: cylinder
  class: row-3-col-3
}

browser -> cdn: static assets
browser -> api: REST calls
api -> db: queries
api -> cache: session data
cdn -> api: origin fetch
