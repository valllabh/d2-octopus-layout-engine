# Test 23: Layered architecture (4 rows)
classes: {
  row-1-col-1: {style.opacity: 1}
  row-1-col-2: {style.opacity: 1}
  row-1-col-3: {style.opacity: 1}
  row-2-col-1: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  row-2-col-3: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-2: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
  row-4-col-1: {style.opacity: 1}
  row-4-col-2: {style.opacity: 1}
}

# Presentation Layer
web: Web UI {class: row-1-col-1}
mobile: Mobile {class: row-1-col-2}
cli: CLI {class: row-1-col-3}

# Service Layer
auth-svc: Auth {class: row-2-col-1}
biz-svc: Business Logic {class: row-2-col-2}
notif-svc: Notifications {class: row-2-col-3}

# Data Access Layer
repo: Repository {class: row-3-col-1}
cache-layer: Cache Layer {class: row-3-col-2}
search: Search Index {class: row-3-col-3}

# Storage Layer
postgres: PostgreSQL {
  shape: cylinder
  class: row-4-col-1
}
redis: Redis {
  shape: cylinder
  class: row-4-col-2
}

web -> auth-svc
web -> biz-svc
mobile -> auth-svc
mobile -> biz-svc
cli -> biz-svc
biz-svc -> repo
biz-svc -> cache-layer
biz-svc -> notif-svc
repo -> postgres
cache-layer -> redis
search -> postgres
