# Test 13: Mixed shapes
classes: {
  row-1-col-2: {style.opacity: 1}
  row-2-col-1: {style.opacity: 1}
  row-2-col-3: {style.opacity: 1}
  row-3-col-2: {style.opacity: 1}
  row-4-col-2: {style.opacity: 1}
}

user: User {
  shape: person
  class: row-1-col-2
}
decision: Route? {
  shape: diamond
  class: row-2-col-1
}
api: API {
  shape: hexagon
  class: row-2-col-3
}
db: Storage {
  shape: cylinder
  class: row-3-col-2
}
event: Done {
  shape: circle
  class: row-4-col-2
}

user -> decision
decision -> api
api -> db
db -> event
