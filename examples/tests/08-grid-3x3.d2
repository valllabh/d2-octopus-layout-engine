# Test 8: Full 3x3 grid
classes: {
  row-1-col-1: {style.opacity: 1}
  row-1-col-2: {style.opacity: 1}
  row-1-col-3: {style.opacity: 1}
  row-2-col-1: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  row-2-col-3: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-2: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
}

a: A {class: row-1-col-1}
b: B {class: row-1-col-2}
c: C {class: row-1-col-3}
d: D {class: row-2-col-1}
e: E {class: row-2-col-2}
f: F {class: row-2-col-3}
g: G {class: row-3-col-1}
h: H {class: row-3-col-2}
i: I {class: row-3-col-3}

a -> e: {style.stroke: "#E74C3C"}
b -> e: {style.stroke: "#3498DB"}
c -> e: {style.stroke: "#2ECC71"}
e -> g: {style.stroke: "#F39C12"}
e -> h: {style.stroke: "#9B59B6"}
e -> i: {style.stroke: "#1ABC9C"}
d -> e: {style.stroke: "#E67E22"}
f -> e: {style.stroke: "#2980B9"}
