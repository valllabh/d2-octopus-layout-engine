classes: {
  row-1-col-3: {style.opacity: 1}
  row-2-col-3: {style.opacity: 1}
  row-3-col-2: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
  row-3-col-4: {style.opacity: 1}
  row-4-col-3: {style.opacity: 1}
  row-5-col-3: {style.opacity: 1}
}

user: User {
  shape: person
  class: row-1-col-3
  style.fill: "#E0E0E0"
}

orchestrator: Orchestrator {
  class: row-2-col-3
  style.fill: "#4A90D9"
}

context: Context Manager {
  class: row-3-col-2
  style.fill: "#7EC47E"
}

router: Model Router {
  class: row-3-col-3
  style.fill: "#7EC47E"
}

tools: Tool Executor {
  class: row-3-col-4
  style.fill: "#7EC47E"
}

llm: LLM API {
  class: row-4-col-3
  style.fill: "#A8D8EA"
}

response: Response {
  class: row-5-col-3
  style.fill: "#E0E0E0"
}

user -> orchestrator
orchestrator -> context
orchestrator -> router
orchestrator -> tools
router -> llm
orchestrator -> response
