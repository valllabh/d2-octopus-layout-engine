# Test 14: Nodes with no connections (layout only)
classes: {
  row-1-col-1: {style.opacity: 1}
  row-1-col-3: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
}

a: Alpha {class: row-1-col-1}
b: Beta {class: row-1-col-3}
c: Gamma {class: row-2-col-2}
d: Delta {class: row-3-col-1}
e: Epsilon {class: row-3-col-3}
