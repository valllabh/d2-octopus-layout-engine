# Test 16: Microservices architecture
classes: {
  row-1-col-2: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-2: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
  row-4-col-1: {style.opacity: 1}
  row-4-col-2: {style.opacity: 1}
  row-4-col-3: {style.opacity: 1}
}

client: Mobile App {
  class: row-1-col-2
}
gateway: API Gateway {
  class: row-2-col-2
}
auth: Auth Service {
  class: row-3-col-1
}
users: User Service {
  class: row-3-col-2
}
orders: Order Service {
  class: row-3-col-3
}
auth-db: Auth DB {
  shape: cylinder
  class: row-4-col-1
}
user-db: User DB {
  shape: cylinder
  class: row-4-col-2
}
order-db: Order DB {
  shape: cylinder
  class: row-4-col-3
}

client -> gateway: {style.stroke: "#E74C3C"}
gateway -> auth: {style.stroke: "#3498DB"}
gateway -> users: {style.stroke: "#2ECC71"}
gateway -> orders: {style.stroke: "#F39C12"}
auth -> auth-db: {style.stroke: "#9B59B6"}
users -> user-db: {style.stroke: "#1ABC9C"}
orders -> order-db: {style.stroke: "#E67E22"}
