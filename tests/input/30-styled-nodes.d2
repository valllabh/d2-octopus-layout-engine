# Test 30: Styled nodes with colors
classes: {
  row-1-col-2: {style.opacity: 1}
  row-2-col-1: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  row-2-col-3: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-2: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
  row-4-col-2: {style.opacity: 1}
}

user: User {
  shape: person
  class: row-1-col-2
  style.fill: "#E0E0E0"
}
auth: Auth Service {
  class: row-2-col-1
  style.fill: "#FF6B6B"
  style.font-color: white
}
api: API Layer {
  class: row-2-col-2
  style.fill: "#4ECDC4"
}
cache: Cache {
  class: row-2-col-3
  style.fill: "#FFE66D"
}
db1: Users DB {
  shape: cylinder
  class: row-3-col-1
  style.fill: "#A8D8EA"
}
db2: Orders DB {
  shape: cylinder
  class: row-3-col-2
  style.fill: "#A8D8EA"
}
db3: Analytics DB {
  shape: cylinder
  class: row-3-col-3
  style.fill: "#A8D8EA"
}
report: Reports {
  class: row-4-col-2
  style.fill: "#DDA0DD"
}

user -> auth: login {style.stroke: "#E74C3C"}
user -> api: requests {style.stroke: "#3498DB"}
api -> cache: read {style.stroke: "#2ECC71"}
api -> db1: {style.stroke: "#F39C12"}
api -> db2: {style.stroke: "#9B59B6"}
api -> db3: {style.stroke: "#1ABC9C"}
db3 -> report: generate {style.stroke: "#E67E22"}
auth -> db1: verify {style.stroke: "#2980B9"}
