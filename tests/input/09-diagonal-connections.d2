# Test 9: Diagonal connections across grid
classes: {
  row-1-col-1: {style.opacity: 1}
  row-1-col-3: {style.opacity: 1}
  row-3-col-1: {style.opacity: 1}
  row-3-col-3: {style.opacity: 1}
  row-2-col-2: {style.opacity: 1}
  src-anchor-right-4: {style.opacity: 1}
  dst-anchor-left-2: {style.opacity: 1}
  src-anchor-left-2: {style.opacity: 1}
  dst-anchor-right-4: {style.opacity: 1}
  src-anchor-bottom-4: {style.opacity: 1}
  dst-anchor-top-2: {style.opacity: 1}
  src-anchor-right-2: {style.opacity: 1}
  dst-anchor-left-4: {style.opacity: 1}
}

tl: Top Left {class: row-1-col-1}
tr: Top Right {class: row-1-col-3}
bl: Bottom Left {class: row-3-col-1}
br: Bottom Right {class: row-3-col-3}
center: Center {class: row-2-col-2}

tl -> br: {
  class: src-anchor-right-4
  class: dst-anchor-left-2
  style.stroke: "#E74C3C"
}
tr -> bl: {
  class: src-anchor-left-2
  class: dst-anchor-right-4
  style.stroke: "#3498DB"
}
tl -> center: {
  class: src-anchor-bottom-4
  class: dst-anchor-top-2
  style.stroke: "#2ECC71"
}
center -> br: {
  class: src-anchor-right-2
  class: dst-anchor-left-4
  style.stroke: "#F39C12"
}
